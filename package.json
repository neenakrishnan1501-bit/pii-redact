{
  "name": "pii-redact",
  "version": "1.1.1",
  "description": "A lightweight and extensible library for identifying and redacting Personally Identifiable Information (PII) from structured and unstructured text.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neenakrishnan1501-bit/pii-redact.git"
  },
  "keywords": [
    "pii",
    "redact",
    "redaction",
    "privacy",
    "security",
    "gdpr",
    "ccpa",
    "hipaa",
    "nlp",
    "named-entity-recognition",
    "obfuscation",
    "masking",
    "anonymization",
    "sanitization",
    "data-protection",
    "compliance",
    "data-privacy",
    "log-sanitization",
    "personally-identifiable-information",
    "cybersecurity",
    "typescript"
  ],
  "author": "Neena Krishnan",
  "funding": "https://github.com/sponsors/neenakrishnan1501-bit",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/neenakrishnan1501-bit/pii-redact/issues"
  },
  "homepage": "https://github.com/neenakrishnan1501-bit/pii-redact#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "jest": "^30.2.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "compromise": "^14.15.0",
    "node-html-parser": "^7.1.0"
  }
}
